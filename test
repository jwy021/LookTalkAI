let gazeTimeout = null;
const GRACE_PERIOD_MS = 3000; // 3초 대기

// ⭐️ 현재 루프 속도를 결정하는 변수 (기본 100ms)
let loopDelay = 100;

function handleLookAway() {
  if (speech.isRecording && gazeTimeout === null) {
    statusText.innerText = "👀 잠깐 딴 곳 보는 중...";
    statusText.style.color = "#facc15";

    gazeTimeout = setTimeout(() => {
      statusText.innerText = "대기 상태";
      statusText.style.color = "gray";
      speechBubble.style.display = 'none';
      speechBubble.innerText = "";
      speech.stop();
      gazeTimeout = null;
    }, GRACE_PERIOD_MS);
  }
}

function loop() {
  const result = tracker.checkGaze();

  if (result) {
    if (result.msg === "얼굴 없음") {
      handleLookAway();
      loopDelay = 100; // 얼굴이 없으면 빨리빨리 탐색 (0.1초)
    } else if (result.active) {
      // 🎯 위젯을 쳐다봤을 때!
      if (gazeTimeout !== null) {
        clearTimeout(gazeTimeout);
        gazeTimeout = null;
      }

      if (!speech.isRecording) {
        statusText.innerText = "🎙️ 듣는 중...";
        statusText.style.color = "#4ade80";
        speechBubble.innerText = "듣고 있어요...";
        speechBubble.style.display = 'block';
        speech.start();
      } else {
        statusText.innerText = "🎙️ 듣는 중...";
        statusText.style.color = "#4ade80";
      }

      // ⭐️ 핵심: 이미 나를 보고 대화 중이라면 CPU 낭비 방지를 위해 
      // 감시 주기를 0.5초(500ms)로 확 늦춥니다. (루프가 잠깐 멈추는 효과)
      loopDelay = 500;

    } else {
      // 딴 곳을 볼 때
      handleLookAway();
      // 시선이 벗어나면 언제 다시 돌아올지 모르니 다시 빨리빨리 탐색 (0.1초)
      loopDelay = 100;
    }
  }

  // ⭐️ setInterval 대신, 상태에 따라 변하는 loopDelay만큼 기다렸다가 자기 자신을 다시 호출
  setTimeout(loop, loopDelay);
}

async function startApp() {
  try {
    statusText.innerText = "AI 로딩 중...";
    await tracker.init();

    const stream = await navigator.mediaDevices.getUserMedia({
