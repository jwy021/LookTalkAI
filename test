    });
    video.srcObject = stream;

    video.onloadedmetadata = () => {
      video.play();
      statusText.innerText = "준비 완료!";

      // ⭐️ 시작할 때 단 한 번만 loop를 찔러주면, 그 뒤론 알아서 속도를 조절하며 돕니다.
      loop();
    };

  } catch (err) {
    statusText.innerText = "초기화 에러!";
    console.error(err);
